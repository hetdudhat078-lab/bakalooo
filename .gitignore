<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width,initial-scale=1.0,maximum-scale=1.0,user-scalable=no">
<title>Bakalooo - Minutes Delivery</title>
<script src="https://cdn.tailwindcss.com"></script>
<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
<link href="https://fonts.googleapis.com/css2?family=Outfit:wght@300;400;500;600;700;800;900&family=DM+Sans:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<script>
tailwind.config={theme:{extend:{colors:{g50:'#e6f7ed',g100:'#b8e6cd',g200:'#8ad4ac',g300:'#5cc28b',g400:'#2eb06a',g500:'#0d6b3f',g600:'#0a5532',g700:'#073f25',g800:'#052a18',g900:'#02150c'},fontFamily:{display:['Outfit','sans-serif'],body:['DM Sans','sans-serif']}}}}
</script>
<style>
*{margin:0;padding:0;box-sizing:border-box;-webkit-tap-highlight-color:transparent}
html{scroll-behavior:smooth}
body{font-family:'DM Sans',sans-serif;background:#f0f7f2;overflow-x:hidden}
::-webkit-scrollbar{width:6px;height:4px}
::-webkit-scrollbar-track{background:transparent}
::-webkit-scrollbar-thumb{background:#2eb06a;border-radius:10px}
.view{display:none;min-height:100vh;flex-direction:column}
.view.active{display:flex}
.slide-up{animation:slideUp .35s cubic-bezier(.16,1,.3,1)}
@keyframes slideUp{from{opacity:0;transform:translateY(30px)}to{opacity:1;transform:translateY(0)}}
.fade-in{animation:fadeIn .3s ease}
@keyframes fadeIn{from{opacity:0}to{opacity:1}}
.hero-gradient{background:linear-gradient(135deg,#0d6b3f 0%,#1a9f5c 40%,#2eb06a 70%,#5cc28b 100%)}
.hero-pattern{background-image:radial-gradient(circle at 20% 80%,rgba(255,255,255,.08) 0%,transparent 50%),radial-gradient(circle at 80% 20%,rgba(255,255,255,.06) 0%,transparent 50%)}
.cat-scroll::-webkit-scrollbar{display:none}
.cat-scroll{-ms-overflow-style:none;scrollbar-width:none}
.offers-scroll::-webkit-scrollbar{display:none}
.offers-scroll{-ms-overflow-style:none;scrollbar-width:none}
.product-card{transition:transform .2s ease,box-shadow .2s ease}
.product-card:hover{transform:translateY(-4px);box-shadow:0 12px 28px rgba(13,107,63,.12)}
.qty-btn{transition:all .15s ease}
.qty-btn:active{transform:scale(.9)}
.toast{animation:toastIn .4s cubic-bezier(.16,1,.3,1),toastOut .4s ease 2.2s forwards}
@keyframes toastIn{from{opacity:0;transform:translateY(-20px) scale(.95)}to{opacity:1;transform:translateY(0) scale(1)}}
@keyframes toastOut{to{opacity:0;transform:translateY(-20px) scale(.95)}}
.badge-bounce{animation:badgeBounce .3s cubic-bezier(.16,1,.3,1)}
@keyframes badgeBounce{0%{transform:scale(1)}50%{transform:scale(1.4)}100%{transform:scale(1)}}
.shimmer{background:linear-gradient(90deg,#e6f7ed 25%,#b8e6cd 50%,#e6f7ed 75%);background-size:200% 100%;animation:shimmer 1.5s infinite}
@keyframes shimmer{0%{background-position:200% 0}100%{background-position:-200% 0}}
.float-anim{animation:float 6s ease-in-out infinite}
@keyframes float{0%,100%{transform:translateY(0)}50%{transform:translateY(-10px)}}
.pulse-green{animation:pulseG 2s ease-in-out infinite}
@keyframes pulseG{0%,100%{box-shadow:0 0 0 0 rgba(46,176,106,.4)}70%{box-shadow:0 0 0 12px rgba(46,176,106,0)}}
input:focus,select:focus,textarea:focus{outline:none;border-color:#2eb06a !important;box-shadow:0 0 0 3px rgba(46,176,106,.15)}
.modal-overlay{backdrop-filter:blur(4px)}
@media(min-width:768px){.mobile-frame{max-width:430px;margin:0 auto;box-shadow:0 0 60px rgba(13,107,63,.15);border-radius:24px;overflow:hidden;min-height:100vh}}
</style>
</head>
<body class="bg-g50 font-body">
<div id="app" class="mobile-frame bg-white relative flex flex-col min-h-screen">

<!-- Toast Container -->
<div id="toastContainer" class="fixed top-4 left-1/2 -translate-x-1/2 z-[9999] flex flex-col gap-2 items-center pointer-events-none"></div>

<!-- ===== SPLASH ===== -->
<div id="splashView" class="view active items-center justify-center bg-white" style="min-height:100vh">
<div class="text-center">
<div class="w-28 h-28 mx-auto mb-6 rounded-3xl hero-gradient hero-pattern flex items-center justify-center float-anim shadow-lg shadow-g300/30">
<i class="fas fa-leaf text-white text-5xl"></i>
</div>
<h1 class="font-display text-5xl font-900 text-g600 tracking-tight">Bakalooo</h1>
<p class="text-g400 font-display font-500 mt-2 text-lg">Groceries in minutes</p>
<div class="mt-10 flex justify-center gap-1.5">
<div class="w-2.5 h-2.5 rounded-full bg-g400 animate-bounce" style="animation-delay:0s"></div>
<div class="w-2.5 h-2.5 rounded-full bg-g300 animate-bounce" style="animation-delay:.15s"></div>
<div class="w-2.5 h-2.5 rounded-full bg-g200 animate-bounce" style="animation-delay:.3s"></div>
</div>
</div>
</div>

<!-- ===== LOGIN ===== -->
<div id="loginView" class="view items-center justify-center bg-white px-6" style="min-height:100vh">
<div class="w-full max-w-sm slide-up">
<div class="w-20 h-20 mx-auto mb-5 rounded-2xl hero-gradient flex items-center justify-center shadow-md shadow-g300/30">
<i class="fas fa-leaf text-white text-3xl"></i>
</div>
<h2 class="font-display text-3xl font-800 text-g700 text-center">Welcome Back</h2>
<p class="text-g400 text-center mt-1 mb-8">Login to your Bakalooo account</p>
<div class="space-y-4">
<div>
<label class="text-sm font-600 text-g600 mb-1.5 block">Email Address</label>
<div class="relative"><i class="fas fa-envelope absolute left-4 top-1/2 -translate-y-1/2 text-g300"></i>
<input id="loginEmail" type="email" placeholder="you@email.com" class="w-full pl-11 pr-4 py-3.5 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all"></div>
</div>
<div>
<label class="text-sm font-600 text-g600 mb-1.5 block">Password</label>
<div class="relative"><i class="fas fa-lock absolute left-4 top-1/2 -translate-y-1/2 text-g300"></i>
<input id="loginPass" type="password" placeholder="Enter password" class="w-full pl-11 pr-4 py-3.5 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all"></div>
</div>
<button onclick="handleLogin()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform text-lg">Login</button>
<p class="text-center text-g400 text-sm">Don't have an account? <span onclick="showView('signupView')" class="text-g500 font-600 cursor-pointer hover:underline">Sign Up</span></p>
</div>
</div>
</div>

<!-- ===== SIGNUP ===== -->
<div id="signupView" class="view items-center justify-center bg-white px-6" style="min-height:100vh">
<div class="w-full max-w-sm slide-up">
<div class="w-20 h-20 mx-auto mb-5 rounded-2xl hero-gradient flex items-center justify-center shadow-md shadow-g300/30">
<i class="fas fa-user-plus text-white text-3xl"></i>
</div>
<h2 class="font-display text-3xl font-800 text-g700 text-center">Create Account</h2>
<p class="text-g400 text-center mt-1 mb-6">Join Bakalooo for quick deliveries</p>
<div class="space-y-3">
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">First Name</label>
<input id="signupFirst" type="text" placeholder="John" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Last Name</label>
<input id="signupLast" type="text" placeholder="Doe" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
</div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Email Address</label>
<input id="signupEmail" type="email" placeholder="you@email.com" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Phone Number</label>
<input id="signupPhone" type="tel" placeholder="+91 98765 43210" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Password</label>
<input id="signupPass" type="password" placeholder="Min 6 characters" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Delivery Address</label>
<textarea id="signupAddress" rows="2" placeholder="House No, Street, Area, Landmark..." class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm resize-none"></textarea></div>
<button onclick="handleSignup()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform text-lg mt-2">Create Account</button>
<p class="text-center text-g400 text-sm">Already have an account? <span onclick="showView('loginView')" class="text-g500 font-600 cursor-pointer hover:underline">Login</span></p>
</div>
</div>
</div>

<!-- ===== HOME (Customer) ===== -->
<div id="homeView" class="view bg-g50">
<!-- Top Bar -->
<div class="bg-white sticky top-0 z-50 shadow-sm">
<div class="flex items-center justify-between px-4 py-3">
<div class="flex items-center gap-2">
<div class="w-9 h-9 rounded-xl hero-gradient flex items-center justify-center"><i class="fas fa-leaf text-white text-sm"></i></div>
<span class="font-display font-800 text-xl text-g600">Bakalooo</span>
</div>
<div class="flex items-center gap-3">
<button onclick="showView('searchView')" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center"><i class="fas fa-search text-g500 text-sm"></i></button>
<button onclick="showView('cartView')" class="relative w-9 h-9 rounded-full bg-g50 flex items-center justify-center">
<i class="fas fa-shopping-bag text-g500 text-sm"></i>
<span id="cartBadgeHome" class="hidden absolute -top-1 -right-1 w-5 h-5 bg-red-500 text-white text-[10px] font-700 rounded-full flex items-center justify-center">0</span>
</button>
</div>
</div>
<!-- Location Bar -->
<div onclick="showView('addressView')" class="flex items-center gap-2 px-4 pb-3 cursor-pointer group">
<div class="w-7 h-7 rounded-full bg-g100 flex items-center justify-center"><i class="fas fa-location-dot text-g500 text-xs"></i></div>
<div class="flex-1 min-w-0">
<p class="text-[10px] text-g300 font-500 uppercase tracking-wider">Deliver to</p>
<p id="homeAddress" class="text-sm font-600 text-g700 truncate">Select delivery address...</p>
</div>
<i class="fas fa-chevron-down text-g300 text-xs group-hover:text-g500 transition-colors"></i>
</div>
</div>

<!-- Scrollable Content -->
<div class="flex-1 overflow-y-auto pb-24">
<!-- Hero Banner -->
<div class="mx-4 mt-3 rounded-2xl overflow-hidden hero-gradient hero-pattern relative" style="min-height:180px">
<div class="absolute inset-0 flex flex-col justify-center px-6 z-10">
<div class="inline-flex items-center gap-1.5 bg-white/20 backdrop-blur-sm rounded-full px-3 py-1 w-fit mb-3">
<span class="w-2 h-2 rounded-full bg-green-300 pulse-green"></span>
<span class="text-white text-xs font-600">Delivery in 10 minutes</span>
</div>
<h2 class="font-display text-white text-3xl font-900 leading-tight">Fresh Fruits &<br>Vegetables</h2>
<p class="text-green-100 text-sm mt-2 font-400">Farm fresh produce at your doorstep</p>
<button onclick="scrollToCat('fruits')" class="mt-4 bg-white text-g600 font-display font-700 px-5 py-2.5 rounded-xl text-sm shadow-lg active:scale-95 transition-transform">Shop Now <i class="fas fa-arrow-right ml-1 text-xs"></i></button>
</div>
<div class="absolute right-0 bottom-0 opacity-20 text-[180px] leading-none pointer-events-none select-none">🥬</div>
</div>

<!-- Offers Strip -->
<div id="offersStrip" class="mt-4"></div>

<!-- Categories -->
<div class="mt-5 px-4">
<h3 class="font-display font-700 text-lg text-g700 mb-3">Shop by Category</h3>
<div id="catGrid" class="grid grid-cols-4 gap-3"></div>
</div>

<!-- Products Section -->
<div id="productsSection" class="mt-6 px-4"></div>
</div>

<!-- Bottom Nav -->
<nav class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[430px] bg-white border-t border-g100 z-50 flex items-center justify-around py-2 pb-[max(0.5rem,env(safe-area-inset-bottom))]">
<button onclick="showView('homeView')" class="flex flex-col items-center gap-0.5 px-3 py-1 text-g500 nav-btn" data-nav="home"><i class="fas fa-home text-lg"></i><span class="text-[10px] font-600">Home</span></button>
<button onclick="showView('searchView')" class="flex flex-col items-center gap-0.5 px-3 py-1 text-g300 nav-btn" data-nav="search"><i class="fas fa-search text-lg"></i><span class="text-[10px] font-600">Search</span></button>
<button onclick="showView('cartView')" class="flex flex-col items-center gap-0.5 px-3 py-1 text-g300 nav-btn relative" data-nav="cart"><i class="fas fa-shopping-bag text-lg"></i><span class="text-[10px] font-600">Cart</span><span id="cartBadgeNav" class="hidden absolute -top-0.5 right-1 w-4.5 h-4.5 bg-red-500 text-white text-[9px] font-700 rounded-full flex items-center justify-center min-w-[18px] h-[18px]">0</span></button>
<button onclick="showView('ordersView')" class="flex flex-col items-center gap-0.5 px-3 py-1 text-g300 nav-btn" data-nav="orders"><i class="fas fa-receipt text-lg"></i><span class="text-[10px] font-600">Orders</span></button>
<button onclick="showView('profileView')" class="flex flex-col items-center gap-0.5 px-3 py-1 text-g300 nav-btn" data-nav="profile"><i class="fas fa-user text-lg"></i><span class="text-[10px] font-600">Profile</span></button>
</nav>
</div>

<!-- ===== SEARCH ===== -->
<div id="searchView" class="view bg-white">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center gap-3 border-b border-g100">
<button onclick="showView('homeView')" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center flex-shrink-0"><i class="fas fa-arrow-left text-g600 text-sm"></i></button>
<div class="flex-1 relative"><i class="fas fa-search absolute left-3.5 top-1/2 -translate-y-1/2 text-g300 text-sm"></i>
<input id="searchInput" type="text" placeholder="Search for fruits, vegetables..." class="w-full pl-10 pr-4 py-3 bg-g50 border-2 border-transparent rounded-xl text-g700 placeholder-g300 transition-all" oninput="handleSearch(this.value)"></div>
</div>
<div id="searchResults" class="flex-1 overflow-y-auto px-4 py-4 pb-24"></div>
</div>

<!-- ===== CART ===== -->
<div id="cartView" class="view bg-g50">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center gap-3 border-b border-g100">
<button onclick="showView('homeView')" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center flex-shrink-0"><i class="fas fa-arrow-left text-g600 text-sm"></i></button>
<h2 class="font-display font-700 text-lg text-g700">My Cart</h2>
<span id="cartCount" class="text-sm text-g400 ml-1"></span>
</div>
<div id="cartContent" class="flex-1 overflow-y-auto px-4 py-4 pb-56"></div>
<div id="cartFooter" class="hidden fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[430px] bg-white border-t border-g100 px-4 py-3 z-40"></div>
</div>

<!-- ===== CHECKOUT ===== -->
<div id="checkoutView" class="view bg-g50">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center gap-3 border-b border-g100">
<button onclick="showView('cartView')" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center flex-shrink-0"><i class="fas fa-arrow-left text-g600 text-sm"></i></button>
<h2 class="font-display font-700 text-lg text-g700">Checkout</h2>
</div>
<div id="checkoutContent" class="flex-1 overflow-y-auto px-4 py-4 pb-56"></div>
<div id="checkoutFooter" class="fixed bottom-0 left-1/2 -translate-x-1/2 w-full max-w-[430px] bg-white border-t border-g100 px-4 py-3 z-40"></div>
</div>

<!-- ===== ORDER SUCCESS ===== -->
<div id="successView" class="view items-center justify-center bg-white px-6" style="min-height:100vh">
<div class="text-center slide-up">
<div class="w-24 h-24 mx-auto mb-6 rounded-full bg-g50 flex items-center justify-center"><i class="fas fa-check-circle text-g400 text-5xl"></i></div>
<h2 class="font-display text-3xl font-800 text-g700">Order Placed!</h2>
<p class="text-g400 mt-2">Your order will be delivered in 10 minutes</p>
<p id="successOrderId" class="text-g300 text-sm mt-1"></p>
<div class="mt-8 space-y-3">
<button onclick="showView('ordersView')" class="w-full py-3.5 border-2 border-g200 text-g600 font-display font-700 rounded-xl">View Orders</button>
<button onclick="showView('homeView')" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30">Back to Home</button>
</div>
</div>
</div>

<!-- ===== ORDERS ===== -->
<div id="ordersView" class="view bg-g50">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center gap-3 border-b border-g100">
<button onclick="showView('homeView')" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center flex-shrink-0"><i class="fas fa-arrow-left text-g600 text-sm"></i></button>
<h2 class="font-display font-700 text-lg text-g700">My Orders</h2>
</div>
<div id="ordersContent" class="flex-1 overflow-y-auto px-4 py-4 pb-24"></div>
</div>

<!-- ===== PROFILE ===== -->
<div id="profileView" class="view bg-g50">
<div class="bg-white px-4 py-5 border-b border-g100">
<div class="flex items-center gap-4">
<div class="w-16 h-16 rounded-2xl hero-gradient flex items-center justify-center text-white font-display font-800 text-2xl" id="profileAvatar">J</div>
<div><h2 id="profileName" class="font-display font-700 text-lg text-g700">John Doe</h2><p id="profileEmail" class="text-sm text-g400">john@email.com</p><p id="profilePhone" class="text-sm text-g400">+91 98765 43210</p></div>
</div>
</div>
<div class="flex-1 overflow-y-auto px-4 py-4 pb-24 space-y-2">
<button onclick="showView('addressView')" class="w-full flex items-center gap-4 bg-white p-4 rounded-xl active:bg-g50 transition-colors">
<div class="w-10 h-10 rounded-xl bg-g50 flex items-center justify-center"><i class="fas fa-location-dot text-g500"></i></div>
<div class="flex-1 text-left"><p class="font-600 text-g700 text-sm">Delivery Address</p><p id="profileAddr" class="text-xs text-g400 truncate mt-0.5">Add your address</p></div>
<i class="fas fa-chevron-right text-g300 text-sm"></i>
</button>
<button onclick="showView('ordersView')" class="w-full flex items-center gap-4 bg-white p-4 rounded-xl active:bg-g50 transition-colors">
<div class="w-10 h-10 rounded-xl bg-g50 flex items-center justify-center"><i class="fas fa-receipt text-g500"></i></div>
<div class="flex-1 text-left"><p class="font-600 text-g700 text-sm">My Orders</p><p class="text-xs text-g400 mt-0.5">View your order history</p></div>
<i class="fas fa-chevron-right text-g300 text-sm"></i>
</button>
<div class="pt-4">
<button onclick="handleLogout()" class="w-full py-3.5 border-2 border-red-200 text-red-500 font-display font-600 rounded-xl active:bg-red-50 transition-colors"><i class="fas fa-sign-out-alt mr-2"></i>Logout</button>
</div>
</div>
</div>

<!-- ===== ADDRESS ===== -->
<div id="addressView" class="view bg-white">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center gap-3 border-b border-g100">
<button onclick="goBack()" class="w-9 h-9 rounded-full bg-g50 flex items-center justify-center flex-shrink-0"><i class="fas fa-arrow-left text-g600 text-sm"></i></button>
<h2 class="font-display font-700 text-lg text-g700">Delivery Address</h2>
</div>
<div class="flex-1 overflow-y-auto px-4 py-4 pb-24">
<div class="space-y-4">
<div><label class="text-xs font-600 text-g600 mb-1.5 block">Full Name</label>
<input id="addrName" type="text" placeholder="Your full name" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1.5 block">Phone Number</label>
<input id="addrPhone" type="tel" placeholder="+91 98765 43210" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1.5 block">Address Line</label>
<textarea id="addrLine" rows="3" placeholder="House/Flat No., Building, Street, Area..." class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm resize-none"></textarea></div>
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1.5 block">City</label>
<input id="addrCity" type="text" placeholder="City" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1.5 block">Pincode</label>
<input id="addrPin" type="text" placeholder="360001" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 transition-all text-sm"></div>
</div>
<button onclick="saveAddress()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform mt-2">Save Address</button>
</div>
</div>
</div>

<!-- ===== ADMIN DASHBOARD ===== -->
<div id="adminView" class="view bg-g50">
<div class="bg-white sticky top-0 z-40 px-4 py-3 flex items-center justify-between border-b border-g100">
<div class="flex items-center gap-2">
<div class="w-8 h-8 rounded-lg hero-gradient flex items-center justify-center"><i class="fas fa-leaf text-white text-xs"></i></div>
<span class="font-display font-800 text-g600">Admin Panel</span>
</div>
<button onclick="handleLogout()" class="text-red-400 text-sm font-600"><i class="fas fa-sign-out-alt mr-1"></i>Logout</button>
</div>
<div class="flex-1 overflow-y-auto px-4 py-4 pb-24">
<!-- Stats -->
<div class="grid grid-cols-3 gap-3 mb-5" id="adminStats"></div>
<!-- Tabs -->
<div class="flex bg-white rounded-xl p-1 mb-5 gap-1">
<button onclick="switchAdminTab('products')" class="admin-tab flex-1 py-2.5 rounded-lg text-sm font-600 transition-all" data-tab="products">Products</button>
<button onclick="switchAdminTab('offers')" class="admin-tab flex-1 py-2.5 rounded-lg text-sm font-600 transition-all" data-tab="offers">Offers</button>
<button onclick="switchAdminTab('coupons')" class="admin-tab flex-1 py-2.5 rounded-lg text-sm font-600 transition-all" data-tab="coupons">Coupons</button>
<button onclick="switchAdminTab('orders')" class="admin-tab flex-1 py-2.5 rounded-lg text-sm font-600 transition-all" data-tab="orders">Orders</button>
</div>
<div id="adminTabContent"></div>
</div>
</div>

<!-- ===== MODAL (Add/Edit Product) ===== -->
<div id="productModal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center">
<div class="modal-overlay absolute inset-0 bg-black/40" onclick="closeProductModal()"></div>
<div class="relative bg-white w-full max-w-[430px] max-h-[90vh] rounded-t-3xl sm:rounded-3xl overflow-y-auto slide-up">
<div class="sticky top-0 bg-white px-5 py-4 border-b border-g100 flex items-center justify-between z-10">
<h3 id="modalTitle" class="font-display font-700 text-lg text-g700">Add Product</h3>
<button onclick="closeProductModal()" class="w-8 h-8 rounded-full bg-g50 flex items-center justify-center"><i class="fas fa-times text-g400 text-sm"></i></button>
</div>
<div class="p-5 space-y-3">
<input type="hidden" id="editProductId">
<div><label class="text-xs font-600 text-g600 mb-1 block">Product Name</label>
<input id="pName" type="text" placeholder="e.g. Organic Tomatoes" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Category</label>
<select id="pCat" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 text-sm"></select></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Unit</label>
<select id="pUnit" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 text-sm">
<option value="kg">kg</option><option value="g">g</option><option value="pc">piece</option><option value="dozen">dozen</option><option value="pack">pack</option><option value="bunch">bunch</option><option value="litre">litre</option><option value="ml">ml</option>
</select></div>
</div>
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Price (₹)</label>
<input id="pPrice" type="number" placeholder="49" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">MRP (₹)</label>
<input id="pMrp" type="number" placeholder="65" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
</div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Image Keyword (for photo)</label>
<input id="pImg" type="text" placeholder="e.g. tomato, apple, bread" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm">
<p class="text-[10px] text-g300 mt-1">Single word used to fetch product image</p></div>
<div id="pImgPreview" class="hidden"><label class="text-xs font-600 text-g600 mb-1 block">Preview</label>
<img id="pImgPreviewSrc" class="w-20 h-20 rounded-xl object-cover border-2 border-g100"></div>
<button onclick="previewProductImg()" class="text-sm text-g500 font-600"><i class="fas fa-eye mr-1"></i>Preview Image</button>
<div><label class="text-xs font-600 text-g600 mb-1 block">Description</label>
<textarea id="pDesc" rows="2" placeholder="Brief description..." class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm resize-none"></textarea></div>
<button onclick="saveProduct()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform">Save Product</button>
</div>
</div>
</div>

<!-- ===== MODAL (Add Offer) ===== -->
<div id="offerModal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center">
<div class="modal-overlay absolute inset-0 bg-black/40" onclick="closeOfferModal()"></div>
<div class="relative bg-white w-full max-w-[430px] rounded-t-3xl sm:rounded-3xl overflow-y-auto slide-up">
<div class="sticky top-0 bg-white px-5 py-4 border-b border-g100 flex items-center justify-between z-10">
<h3 class="font-display font-700 text-lg text-g700">Add Offer</h3>
<button onclick="closeOfferModal()" class="w-8 h-8 rounded-full bg-g50 flex items-center justify-center"><i class="fas fa-times text-g400 text-sm"></i></button>
</div>
<div class="p-5 space-y-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Offer Title</label>
<input id="oTitle" type="text" placeholder="e.g. 50% Off on Fruits" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Description</label>
<input id="oDesc" type="text" placeholder="Short description" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Discount %</label>
<input id="oDiscount" type="number" placeholder="30" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Background Color</label>
<input id="oColor" type="color" value="#0d6b3f" class="w-full h-[46px] rounded-xl border-2 border-g100 cursor-pointer"></div>
</div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Applicable Category (leave empty for all)</label>
<select id="oCat" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 text-sm">
<option value="">All Categories</option>
</select></div>
<button onclick="saveOffer()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform">Save Offer</button>
</div>
</div>
</div>

<!-- ===== MODAL (Add Coupon) ===== -->
<div id="couponModal" class="hidden fixed inset-0 z-[100] flex items-end sm:items-center justify-center">
<div class="modal-overlay absolute inset-0 bg-black/40" onclick="closeCouponModal()"></div>
<div class="relative bg-white w-full max-w-[430px] rounded-t-3xl sm:rounded-3xl overflow-y-auto slide-up">
<div class="sticky top-0 bg-white px-5 py-4 border-b border-g100 flex items-center justify-between z-10">
<h3 class="font-display font-700 text-lg text-g700">Add Coupon</h3>
<button onclick="closeCouponModal()" class="w-8 h-8 rounded-full bg-g50 flex items-center justify-center"><i class="fas fa-times text-g400 text-sm"></i></button>
</div>
<div class="p-5 space-y-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Coupon Code</label>
<input id="cCode" type="text" placeholder="e.g. BAKALOO50" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm uppercase"></div>
<div class="grid grid-cols-2 gap-3">
<div><label class="text-xs font-600 text-g600 mb-1 block">Discount Type</label>
<select id="cType" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 text-sm">
<option value="percent">Percentage (%)</option><option value="flat">Flat Amount (₹)</option>
</select></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Value</label>
<input id="cValue" type="number" placeholder="50" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
</div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Min Order Value (₹)</label>
<input id="cMin" type="number" placeholder="199" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<div><label class="text-xs font-600 text-g600 mb-1 block">Max Discount (₹, leave 0 for no limit)</label>
<input id="cMax" type="number" placeholder="100" value="0" class="w-full px-4 py-3 border-2 border-g100 rounded-xl text-g700 bg-g50/50 placeholder-g300 text-sm"></div>
<button onclick="saveCoupon()" class="w-full py-3.5 hero-gradient text-white font-display font-700 rounded-xl shadow-lg shadow-g400/30 active:scale-[.97] transition-transform">Save Coupon</button>
</div>
</div>
</div>

</div><!-- /app -->

<script>
/* ===========================
   DATA & STATE
   =========================== */
const ADMIN_EMAIL='hetdudhat078@gmail.com',ADMIN_PASS='hetdudhat9901';
const CATEGORIES=[
{id:'fruits',name:'Fruits',icon:'fa-apple-whole',color:'#e74c3c'},
{id:'vegetables',name:'Vegetables',icon:'fa-carrot',color:'#27ae60'},
{id:'dairy',name:'Dairy',icon:'fa-cheese',color:'#f39c12'},
